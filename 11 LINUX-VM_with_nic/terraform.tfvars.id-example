# -----------------------------------------------------------------------
# Example: public IP passed as a full resource ID (used as-is, no data
# source lookup triggered)
# Rename to terraform.tfvars to use directly, or run with:
#   terraform plan -var-file="terraform.tfvars.id-example"
# -----------------------------------------------------------------------

vm_name              = "app01"
location             = "eastus"
resource_group_name  = "rg-app-prod"
subnet_id            = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-network/providers/Microsoft.Network/virtualNetworks/vnet-prod/subnets/snet-app"
availability_zone    = "1"
vm_size              = "Standard_D2s_v5"
admin_username       = "azureadmin"
authentication_type  = "ssh"
ssh_public_key       = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQ... user@host"

publisher     = "Canonical"
offer         = "0001-com-ubuntu-server-jammy"
sku           = "22_04-lts-gen2"
image_version = "latest"

# ---- Public IP: reuse an existing one, referenced by full resource ID ----
create_public_ip = false
public_ip_input  = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-network/providers/Microsoft.Network/publicIPAddresses/pip-app01-existing"
